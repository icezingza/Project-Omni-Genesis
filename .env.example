# ============================================
# Project Omni-Genesis - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ============================================
# Application Settings
# ============================================
APP_NAME=Project Omni-Genesis
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# SECURITY - REQUIRED IN PRODUCTION
# ============================================
# Generate strong secrets using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production
API_MASTER_KEY=your-master-api-key-change-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS Settings
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ============================================
# Database
# ============================================
# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./omni_genesis.db

# PostgreSQL (Production) - Uncomment to use
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/omni_genesis

# ============================================
# Redis (Optional)
# ============================================
# Uncomment to enable Redis caching
# REDIS_URL=redis://localhost:6379/0

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=30
AUTH_RATE_LIMIT_PER_MINUTE=10

# ============================================
# AI API Keys
# ============================================
# Google Gemini (Required)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (Optional)
# OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude (Optional)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ElevenLabs TTS (Optional)
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================
# Feature Flags
# ============================================
SAFETY_FILTER_ENABLED=true
NSFW_ALLOWED=false
ENABLE_AROUSAL_DETECTOR=false

# ============================================
# Golden Ratio / Emotion Settings
# ============================================
PHI=1.618033988749895
GOLDEN_RATIO_BALANCE_THRESHOLD=0.15

# ============================================
# Monitoring (Optional)
# ============================================
# SENTRY_DSN=your-sentry-dsn
# PROMETHEUS_PORT=9090

# ============================================
# Frontend Settings (for frontend/.env.local)
# ============================================
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
